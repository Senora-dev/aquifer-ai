# MCP server image (runs on Fargate, fronted by an internal NLB).
FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install dependencies first for better layer caching.
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --upgrade pip && pip install ".[aws,mcp]"

# The MCP server listens on the configured port (default 8080).
EXPOSE 8080

# Runtime configuration is injected by the CDK stack as AQUIFER_* env vars.
CMD ["python", "-m", "aquifer.mcp.server"]
